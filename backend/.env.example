# ══════════════════════════════════════════════════════════════
# Smart Building API — Variáveis de Ambiente
# Copie este arquivo para '.env' e preencha os valores reais.
# NUNCA commite o .env com segredos no Git!
# ══════════════════════════════════════════════════════════════

# ── Aplicação ────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Banco de Dados ──────────────────────────────────────────
# Formato: postgresql+asyncpg://{user}:{password}@{host}:{port}/{dbname}
DATABASE_URL=postgresql+asyncpg://smartbuilding:segura123@db:5432/smartbuilding

# ── JWT (gere com: openssl rand -hex 32) ──────────────────
JWT_SECRET=TROQUE-POR-UMA-CHAVE-ALEATORIA-DE-32-CHARS-MINIMO
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MQTT Broker ────────────────────────────────────────────
MQTT_BROKER=mqtt
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# ── CORS ───────────────────────────────────────────────────
# Origens separadas por vírgula
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Token dos Sensores IoT ─────────────────────────────────
# Token Bearer usado pelos containers sensor_* para autenticar
SENSOR_SERVICE_TOKEN=sensor-service-token-dev

# ── Tarifas ────────────────────────────────────────────────
ENERGIA_TARIFA_KWH_BRL=0.75
